{
  "name": "anime-dl-app",
  "version": "4.1.13",
  "description": "Anime episode downloader",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack:win": "electron-vite build && electron-builder --win --dir",
    "pack:linux": "electron-vite build && electron-builder --linux --dir",
    "pack:mac": "electron-vite build && electron-builder --mac --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:subscription-contract": "bash scripts/check-subscription-contract.sh",
    "screenshot": "node scripts/screenshot.js"
  },
  "build": {
    "appId": "com.anime-dl.app",
    "productName": "Anime DL",
    "icon": "resources/icon.png",
    "artifactName": "Anime-DL-${version}-${arch}.${ext}",
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "target": [
        "zip",
        "dmg"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "mikkerlo",
      "repo": "anime-downloader"
    },
    "files": [
      "out/**/*"
    ]
  },
  "keywords": [],
  "author": {
    "name": "mikkerlo",
    "email": "mikhail.semenov.al@gmail.com"
  },
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.10",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "anime4k-webgpu": "^1.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "jassub": "^2.4.2",
    "libass-wasm": "^4.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.31"
  }
}
